{
  "name": "micro-kernel-core",
  "version": "1.0.0",
  "description": "Zero-dependency micro-kernel for extension frameworks (v2.0.0)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.0.9",
    "rollup": "^4.39.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^3.0.9"
  },
  "keywords": [
    "kernel",
    "micro-kernel",
    "extension",
    "plugin",
    "typescript",
    "zero-dependency"
  ],
  "author": "sakasiyhaha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sakasiyhaha/micro-kernel-core.git"
  },
  "bugs": {
    "url": "https://github.com/sakasiyhaha/micro-kernel-core/issues"
  },
  "homepage": "https://github.com/sakasiyhaha/micro-kernel-core#readme"
}
